    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.28",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^6.0.2"
  }
}
